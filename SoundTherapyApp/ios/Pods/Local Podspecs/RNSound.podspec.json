{
  "name": "RNSound",
  "version": "0.13.0",
  "summary": "React Native module for playing sound clips on iOS, Android, and Windows",
  "license": "MIT",
  "authors": "Zhen Wang <z@zmxv.com> (http://blog.zmxv.com)",
  "homepage": "https://github.com/zmxv/react-native-sound",
  "platforms": {
    "ios": "9.0"
  },
  "source": {
    "git": "https://github.com/zmxv/react-native-sound.git"
  },
  "source_files": "ios/**/*.{h,m,mm,cpp}",
  "compiler_flags": "-DFOLLY_NO_CONFIG -DFOLLY_MOBILE=1 -DFOLLY_USE_LIBCPP=1 -DFOLLY_CFG_NO_COROUTINES=1 -Wno-comma -Wno-shorten-64-to-32",
  "dependencies": {
    "React-Core": [],
    "RCT-Folly": [
      "2022.05.16.00"
    ],
    "glog": []
  },
  "pod_target_xcconfig": {
    "HEADER_SEARCH_PATHS": "\"$(PODS_ROOT)/boost\" \"$(PODS_ROOT)/Headers/Private/Yoga\"",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++20"
  }
}
